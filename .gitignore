# ============================================================
# Tarang Monorepo — Root .gitignore
# Covers: Next.js (home, app) + Python/FastAPI (api)
# ============================================================

# --- Dependencies ---
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js ---
.next/
out/
build/
.vercel/

# --- Vite (legacy, if any) ---
dist/
dist-ssr/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
wheels/
.venv/
venv/
env/

# --- Environment files ---
.env
.env.*
!.env.example
!.env.local.example

# --- OS / IDE ---
.DS_Store
*.pem
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.idea/
.vscode/*
!.vscode/extensions.json

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing ---
coverage/

# --- Misc ---
*.local

# script and test audio
push_history.ps1
input_wav/

# python tooling - not needed in repo
.uv-cache/
uv.lock
skills-lock.json
add_clone_stage_columns.py

# build output
.next/
out/

# AI context and planning
Agent.md
Plans/
